!.yarn/plugins
!.yarn/releases
!.yarn/versions
package-lock.json
yarn.lock
pnpm-lock.yaml

# testing
/coverage
.nyc_output

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

